@model HelloWorldMVC1.Models.MCalculator

@{
    ViewBag.Title = "Index";
}

<html>
    <head>

    </head>

    <body>
        <h2> Simple Calculator</h2>
    

    <div class="row">

        @using (Html.BeginForm("/Index","Calculator",FormMethod.Post))
        {
            <div class="form-group">
                <label for="no1"> No 1</label>"
                <input type="text" class="form-control" id="no1" name="no1" value="@Model.a" />
            </div>

            <div class="form-group">
                <label for="no2"> No 2</label>"
                <input type="text" class="form-control" id="no2" name="no2" value="@Model.b" />
            </div>

            <div class="form-group">
                <label for="action"> action</label>"
                <input type="text" class="form-control" id="action" name="action" value="@Model.action" />
            </div>

            <button type="submit" class="btn btn-info" id="add" value="add" name="calculate">+</button>
            <button type="submit" class="btn btn-info" id="add" value="min" name="calculate">-</button>
            <button type="submit" class="btn btn-info" id="add" value="multi" name="calculate">*</button>

            <button type="submit" class="btn btn-info" id="add" value="div" name="calculate">/</button>

        }

    </div>

</body>

</html>